# =============================================================================
# Problem Context Store — environment variables
# Copy this file to `.env` and fill in any values you've changed from defaults.
# =============================================================================

# -------- Database --------
# Postgres connection string. The `pgvector` extension must be installed.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/problem_context_store?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/problem_context_store?schema=public"

# -------- App --------
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -------- Auth (M2) ---------------------------------------------------------
# Required. Generate one with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-real-secret"

# Auth.js base URL. REQUIRED whenever the app is reached through a tunnel,
# reverse proxy, or any host that's different from the one Next.js sees on
# the request (cloudflared, ngrok, Vercel preview, production domain, etc.).
# Without this, magic-link callbacks redirect to localhost and Auth.js raises
# a generic "Verification" error.
#
# Local-only dev (no tunnel): you can leave AUTH_URL unset.
# With a tunnel (recommended for Slack/OAuth dev): set it AND AUTH_TRUST_HOST.
# AUTH_URL="https://yourdomain.com"
# AUTH_TRUST_HOST=true

# Magic-link sender — leave RESEND_API_KEY blank during dev to print the
# sign-in link to your `pnpm dev` terminal instead of sending an email.
# RESEND_API_KEY=""
EMAIL_FROM="Problem Context Store <onboarding@resend.dev>"

# Google OAuth — optional. If not set, the "Continue with Google" button is hidden.
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# -------- Queue / Redis (M9 — required for the background worker) -----------
# The background worker (apps/web/scripts/worker.ts) drains the BullMQ ingest
# queue. Webhooks enqueue jobs and return 200 immediately; the worker runs
# the resolver + embeddings + LLM judge async.
#
# Quickest setup: free Upstash Redis at https://upstash.com
#   1. Create database (any region close to you)
#   2. Copy the "Redis URL" from the database overview page
#   3. Paste below. Format: rediss://default:<pw>@<host>.upstash.io:6379
# REDIS_URL=""

# Optional: tune worker concurrency. With local Ollama on M1, keep at 1.
# With cloud LLM providers (Anthropic/OpenAI) you can crank to 5-10.
# WORKER_CONCURRENCY=1

# -------- Intelligence: embeddings + LLM judge (M6 resolver) ----------------
# The resolver works in three modes:
#   1. No providers configured → rules only.
#   2. Embeddings provider → vector matching.
#   3. Embeddings + LLM judge → full pipeline.

# Free local default — install Ollama (https://ollama.com), then:
#     ollama pull nomic-embed-text
#     ollama pull llama3.1:8b
# OLLAMA_BASE_URL="http://localhost:11434"
# OLLAMA_EMBEDDING_MODEL="nomic-embed-text"
# OLLAMA_LLM_MODEL="llama3.1:8b"

# Summarization model (M7). Used by the "Generate summary" button on the
# Problem detail page. Defaults to OLLAMA_LLM_MODEL if not set. The judge runs
# on every webhook (latency-sensitive) while summaries run on a button click
# (quality-sensitive) — so you may want them to be different models.
#
# Open-weights options, in rough quality-per-MB order:
#   qwen2.5:7b-instruct   (~4.7 GB, Apache 2.0)  best small-LLM for JSON + summaries
#   llama3.1:8b           (~4.6 GB, Llama)       solid all-rounder, what the judge uses
#   qwen2.5:3b-instruct   (~1.9 GB, Apache 2.0)  punches above its weight, fast
#   llama3.2:3b-instruct  (~2.0 GB, Llama)       stable JSON output, fast
#   phi3.5:3.8b           (~2.2 GB, MIT)         strong reasoning, sometimes verbose
# OLLAMA_SUMMARY_MODEL="llama3.1:8b"

# Paid alternatives — use these instead of (or alongside) Ollama. If both are
# set, EMBEDDINGS_PROVIDER / LLM_PROVIDER picks. Default auto-detect prefers
# Ollama, then OpenAI/Anthropic, then no-op.
# EMBEDDINGS_PROVIDER="ollama"   # or "openai"
# LLM_PROVIDER="ollama"           # or "anthropic"

# Paid embedding/LLM (only used if their providers are selected)
# OPENAI_API_KEY=""
# EMBEDDING_MODEL="text-embedding-3-small"
# ANTHROPIC_API_KEY=""
# ANTHROPIC_MODEL="claude-sonnet-4-5"
# ANTHROPIC_SUMMARY_MODEL="claude-sonnet-4-5"  # optional override for summaries

# -------- Slack connector (M8a) ---------------------------------------------
# Create a Slack app at https://api.slack.com/apps, then:
#   1. Basic Information → copy `Client ID`, `Client Secret`, `Signing Secret`.
#   2. OAuth & Permissions → Redirect URLs → add NEXT_PUBLIC_APP_URL/api/auth/slack/callback
#   3. Event Subscriptions → enable, set Request URL = NEXT_PUBLIC_APP_URL/api/ingest/slack
#   4. Subscribe to bot events: message.channels, message.groups, message.im, message.mpim, app_mention
#   5. Manage Distribution → "Distribute App" (so any Slack workspace can install).
#
# For local development:
#   - Use ngrok or similar to give Slack a public HTTPS URL:
#       ngrok http 3000
#     then set NEXT_PUBLIC_APP_URL to the ngrok URL while testing.
#
# SLACK_CLIENT_ID=""
# SLACK_CLIENT_SECRET=""
# SLACK_SIGNING_SECRET=""

# Encrypts bot tokens at rest in ConnectorInstance.config.botTokenEnc.
# Generate one with: openssl rand -hex 32
# Required as soon as you wire up Slack (or any OAuth connector).
# PCS_ENCRYPTION_KEY=""

# -------- Gmail connector (M8b) ---------------------------------------------
# Create OAuth credentials at https://console.cloud.google.com:
#   1. Create a new GCP project (free).
#   2. APIs & Services → Library → enable "Gmail API".
#   3. APIs & Services → OAuth consent screen → External → fill basics,
#      add scopes ".../auth/gmail.readonly", ".../auth/userinfo.email",
#      ".../auth/userinfo.profile", "openid". Add your test email under
#      "Test users" (lets you skip Google's app verification while you're
#      under 100 users).
#   4. APIs & Services → Credentials → Create OAuth client ID → Web app:
#        Authorized redirect URI: NEXT_PUBLIC_APP_URL/api/auth/google/callback
#   5. Copy the Client ID + Client Secret below.
#
# Note: these are SEPARATE from AUTH_GOOGLE_ID/SECRET (which are for user
# sign-in via Auth.js). The Gmail connector needs much broader scopes.
# GMAIL_CLIENT_ID=""
# GMAIL_CLIENT_SECRET=""

# -------- Object storage (added in M5) ---------------------------------------
# S3_ENDPOINT=""
# S3_BUCKET=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""

# -------- Observability (added in M10) ---------------------------------------
# SENTRY_DSN=""
